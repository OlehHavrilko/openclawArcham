# ================================================
# OpenClaw Arkham Intel Agent Configuration
# ================================================
# Copy this file to .env and fill in your values
# ================================================

# Web3 RPC URL (Ethereum mainnet or preferred network)
WEB3_RPC_URL=

# Pinata IPFS API credentials
# Get them at: https://www.pinata.cloud/
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Telegram Bot credentials
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Wallet for blockchain transactions
# WARNING: Never commit private key to version control!
WORKER_WALLET_PRIVATE_KEY=

# Arkham smart contract address for bounty submissions
ARKHAM_CONTRACT_ADDRESS=